#!/usr/bin/env node
/**
 * build-previews — generate 640×360 preview.webp files for every
 * scene source tree in _tools/catalog-sources/scenes/<slug>/ by
 * loading scene.js into a headless Chromium tab, running Pixi for a
 * few seconds, and encoding the canvas as WebP into the same directory.
 *
 * Usage:
 *   node odd/bin/build-previews            # refresh every scene
 *   node odd/bin/build-previews --only flux,aurora
 *   node odd/bin/build-previews --diff     # only rebuild scenes whose
 *                                          source changed since the
 *                                          existing preview was written
 *
 * Dependencies: Playwright (already a repo dev-dep; `npx playwright
 * install chromium --with-deps` has to have run). WebP encoding goes
 * through Chromium's canvas.toBlob('image/webp', 0.8), so no native
 * encoder is required.
 *
 * The script produces previews that look like the scene, not static
 * thumbnails of the painted backdrop — that's the whole point. We
 * sample a frame 2s after `setup` so procedurals (flux ribbons,
 * aurora curtains) have developed their characteristic look.
 */
import { chromium } from '@playwright/test';
import { promises as fs } from 'node:fs';
import { existsSync, statSync, readFileSync, readdirSync } from 'node:fs';
import { dirname, resolve } from 'node:path';
import { fileURLToPath } from 'node:url';

const __dirname = dirname( fileURLToPath( import.meta.url ) );
const PLUGIN_ROOT = resolve( __dirname, '..' );
const REPO_ROOT   = resolve( PLUGIN_ROOT, '..' );
const SCENES_DIR  = resolve( REPO_ROOT, '_tools/catalog-sources/scenes' );

const WIDTH = 640;
const HEIGHT = 360;
const SAMPLE_AT_MS = 2200;

function parseArgs() {
	const args = process.argv.slice( 2 );
	let only = null;
	let diff = false;
	for ( let i = 0; i < args.length; i++ ) {
		const a = args[ i ];
		if ( a === '--only' ) {
			only = new Set( ( args[ ++i ] || '' ).split( ',' ).map( ( s ) => s.trim() ).filter( Boolean ) );
		} else if ( a === '--diff' ) {
			diff = true;
		} else if ( a === '--help' || a === '-h' ) {
			console.log( 'usage: build-previews [--only slug1,slug2] [--diff]' );
			process.exit( 0 );
		}
	}
	return { only, diff };
}

function loadScenes() {
	if ( ! existsSync( SCENES_DIR ) ) return [];
	const out = [];
	for ( const slug of readdirSync( SCENES_DIR ).sort() ) {
		const dir = resolve( SCENES_DIR, slug );
		if ( ! statSync( dir ).isDirectory() ) continue;
		const metaPath = resolve( dir, 'meta.json' );
		const meta = existsSync( metaPath ) ? JSON.parse( readFileSync( metaPath, 'utf8' ) ) : {};
		out.push( { slug, ...meta, _dir: dir } );
	}
	return out;
}

async function run() {
	const { only, diff } = parseArgs();
	const scenes = loadScenes();

	const targets = scenes.filter( ( s ) => {
		if ( only && ! only.has( s.slug ) ) return false;
		if ( diff ) {
			const scenePath = resolve( s._dir, 'scene.js' );
			const previewPath = resolve( s._dir, 'preview.webp' );
			if ( ! existsSync( scenePath ) ) return false;
			if ( ! existsSync( previewPath ) ) return true;
			try {
				return statSync( scenePath ).mtimeMs > statSync( previewPath ).mtimeMs;
			} catch ( _e ) { return true; }
		}
		return true;
	} );

	if ( targets.length === 0 ) {
		console.log( '[build-previews] nothing to do' );
		return;
	}

	console.log( `[build-previews] rebuilding ${ targets.length } preview(s)` );
	const browser = await chromium.launch();
	try {
		for ( const scene of targets ) {
			try {
				await buildOne( browser, scene );
			} catch ( e ) {
				console.error( `[build-previews] ${ scene.slug } failed:`, e && e.message || e );
			}
		}
	} finally {
		await browser.close();
	}
}

async function buildOne( browser, scene ) {
	const scenePath = resolve( scene._dir, 'scene.js' );
	if ( ! existsSync( scenePath ) ) {
		throw new Error( `missing scene source: ${ scenePath }` );
	}
	const sceneSrc = readFileSync( scenePath, 'utf8' );

	const page = await browser.newPage( { viewport: { width: WIDTH, height: HEIGHT } } );
	try {
		await page.setContent( buildHtml( scene, sceneSrc ), { waitUntil: 'domcontentloaded' } );
		await page.waitForFunction( () => window.__ODD_READY === true, null, { timeout: 15_000 } );
		await page.waitForTimeout( SAMPLE_AT_MS );

		const base64 = await page.evaluate( async () => {
			const canvas = document.querySelector( 'canvas' );
			if ( ! canvas ) throw new Error( 'no canvas' );
			const blob = await new Promise( ( r ) => canvas.toBlob( r, 'image/webp', 0.82 ) );
			if ( ! blob ) throw new Error( 'toBlob returned null' );
			const ab = await blob.arrayBuffer();
			let bin = '';
			const u = new Uint8Array( ab );
			for ( let i = 0; i < u.byteLength; i++ ) bin += String.fromCharCode( u[ i ] );
			return btoa( bin );
		} );

		const outPath = resolve( scene._dir, 'preview.webp' );
		await fs.mkdir( dirname( outPath ), { recursive: true } );
		await fs.writeFile( outPath, Buffer.from( base64, 'base64' ) );
		console.log( `  ✓ ${ scene.slug } → ${ outPath.replace( REPO_ROOT + '/', '' ) }` );
	} finally {
		await page.close();
	}
}

function buildHtml( scene, sceneSrc ) {
	const wallpaperPath = resolve( scene._dir, 'wallpaper.webp' );
	const wallpaperUrl = existsSync( wallpaperPath )
		? `data:image/webp;base64,${ readFileSync( wallpaperPath ).toString( 'base64' ) }`
		: '';
	return `<!DOCTYPE html>
<html><head><meta charset="utf-8">
<style>html,body{margin:0;width:${ WIDTH }px;height:${ HEIGHT }px;background:${ scene.fallbackColor || '#0a0a1f' }}</style>
<script src="https://cdn.jsdelivr.net/npm/pixi.js@8/dist/pixi.min.js"></script>
</head>
<body>
<script>
window.__odd = { scenes: {}, helpers: {
	rand: (a,b) => a + Math.random() * (b-a),
	irand: (a,b) => Math.floor(a + Math.random() * (b-a)),
	choose: (arr) => arr[ Math.floor( Math.random() * arr.length ) ],
	clamp: (v,lo,hi) => Math.max(lo, Math.min(hi,v)),
	tau: Math.PI * 2,
	lerpColor: () => 0xffffff,
	paintVGradient: () => {},
	makeBloomLayer: (PIXI) => { const c = new PIXI.Container(); c.blendMode = 'add'; return c; },
	computeTod: () => ({ phase: 'day', amount: 0.5 }),
	computeSeason: () => 'summer',
} };
window.odd = { sceneMap: { '${ scene.slug }': { wallpaperUrl: ${ JSON.stringify( wallpaperUrl ) } } } };
</script>
<script>${ sceneSrc }</script>
<script>
( async function () {
	const app = new PIXI.Application();
	await app.init( { width: ${ WIDTH }, height: ${ HEIGHT }, background: '${ scene.fallbackColor || '#0a0a1f' }', antialias: true, preserveDrawingBuffer: true } );
	document.body.appendChild( app.canvas );
	const scene = window.__odd.scenes[ '${ scene.slug }' ];
	if ( ! scene ) { console.error( 'scene not registered' ); return; }
	const env = {
		app, PIXI,
		ctx: { pluginUrl: '', version: 'preview' },
		helpers: window.__odd.helpers,
		dt: 1,
		parallax: { x: 0, y: 0 },
		reducedMotion: false,
		tod: { phase: 'day', amount: 0.5 },
		todPhase: 'day', season: 'summer',
		audio: { enabled: false, level: 0, bass: 0, mid: 0, high: 0 },
		perfTier: 'normal',
	};
	const state = await scene.setup( env );
	app.ticker.add( ( ticker ) => { env.dt = Math.min( 2.5, ticker.deltaTime ); scene.tick( state, env ); } );
	window.__ODD_READY = true;
} )();
</script>
</body></html>`;
}

run().catch( ( e ) => { console.error( e && e.stack || e ); process.exit( 1 ); } );
