#!/usr/bin/env python3
"""Validate the ODD v3 remote catalog.

Runs every bundle described in `site/catalog/v1/registry.json` against
the same gate the plugin enforces at install time. Catches broken
hashes, schema drift, missing bundle files, and starter-pack entries
that don't resolve. Fails the CI job on any mismatch.

Checks:
  1. Registry JSON parses and matches the schema in
     `site/catalog/v1/registry.schema.json`.
     When `registry.json.sig` exists, or signature validation is
     required by env, it must verify against the bundled public key.
  2. `version` is 1.
  3. Every starter_pack entry (scenes[], iconSets[], cursorSets[], widgets[], apps[])
     names a slug that exists in `bundles[]` with the matching type.
  4. Every `bundles[]` row:
        a. `download_url`, `icon_url`, and `card_url` resolve to files
           on disk under `site/catalog/v1/`.
        b. The `.wp` opens as a ZIP and contains `manifest.json`.
        c. The manifest's `type`, `slug`, and `version` match the row.
        d. The on-disk file's size matches `size`.
        e. The on-disk file's sha256 matches `sha256`.
  5. `odd/data/fallback-registry.json` is byte-identical to the
     published registry.
  6. Rebuilding the catalog from `_tools/catalog-sources/` is
     byte-identical to what's on disk, including icons and the fallback
     registry (determinism check — only runs when ODD_VALIDATE_REBUILD=1,
     default off so local usage stays fast, opt-in for CI).

Exit code 0 on success, non-zero with a bullet list of problems.
"""
from __future__ import annotations

import base64
import hashlib
import json
import io
import os
import re
import subprocess
import sys
import zipfile
from pathlib import Path
from typing import Any
from urllib.parse import urlparse

from PIL import Image, ImageChops, ImageStat


HERE = Path(__file__).resolve().parent
PLUGIN_DIR = HERE.parent
REPO_ROOT = PLUGIN_DIR.parent
CATALOG_DIR = REPO_ROOT / "site" / "catalog" / "v1"
REGISTRY = CATALOG_DIR / "registry.json"
REGISTRY_SIG = CATALOG_DIR / "registry.json.sig"
SCHEMA = CATALOG_DIR / "registry.schema.json"
FALLBACK_REGISTRY = REPO_ROOT / "odd" / "data" / "fallback-registry.json"
DEFAULT_CATALOG_PUBLIC_KEY = "2aIvGPQMF//a9ciDvQ8GST7Q8QhfVsM6h1HB3/Td5Gk="

# If a bundle's icon_url / download_url starts with this prefix, strip
# it to resolve against the on-disk catalog.
PUBLIC_PREFIX = "https://odd.regionallyfamous.com/catalog/v1/"
FIRST_PARTY_ICON_KEYS = {
    "odd", "my-wordpress", "content-graph", "recycle-bin", "fallback",
}
ICON_IMAGE_MAX_BYTES = 768 * 1024
ICON_IMAGE_EXTENSIONS = {"png": "PNG", "webp": "WEBP"}
ICON_VISIBLE_ALPHA_THRESHOLD = 32
ICON_VISIBLE_MIN_FILL = 0.80
CATALOG_CARD_SIZE = (1024, 576)
SCENE_CARD_RMS_LIMIT = 10.0
SLUG_RE = re.compile(r"^[a-z0-9][a-z0-9-]*$")
SEMVER_RE = re.compile(r"^[0-9]+\.[0-9]+\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\+[0-9A-Za-z.-]+)?$")
REQUIRES_KEYS = {"odd", "desktopMode", "api"}


def sha256_file(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as fh:
        for chunk in iter(lambda: fh.read(65536), b""):
            h.update(chunk)
    return h.hexdigest()


def signature_required() -> bool:
    return os.environ.get("ODD_VALIDATE_REQUIRE_CATALOG_SIGNATURE") == "1"


def check_registry_signature(problems: list[str]) -> None:
    if not signature_required() and not REGISTRY_SIG.is_file():
        return
    if not REGISTRY_SIG.is_file():
        problems.append("registry.json.sig is missing")
        return
    public_key_raw = (os.environ.get("ODD_CATALOG_PUBLIC_KEY") or DEFAULT_CATALOG_PUBLIC_KEY).strip()
    try:
        public_key = base64.b64decode(public_key_raw, validate=True)
    except Exception as exc:  # noqa: BLE001 - report validation problem and continue.
        problems.append(f"catalog public key is not valid base64: {exc}")
        return
    if len(public_key) != 32:
        problems.append("catalog public key must decode to 32 bytes")
        return
    try:
        signature = base64.b64decode(REGISTRY_SIG.read_text(encoding="utf-8").strip(), validate=True)
    except Exception as exc:  # noqa: BLE001 - report validation problem and continue.
        problems.append(f"registry.json.sig is not valid base64: {exc}")
        return
    if len(signature) != 64:
        problems.append("registry.json.sig must decode to a 64-byte Ed25519 signature")
        return
    try:
        from nacl.exceptions import BadSignatureError
        from nacl.signing import VerifyKey
    except Exception as exc:  # noqa: BLE001 - report validation problem and continue.
        problems.append(f"PyNaCl is required to validate registry.json.sig: {exc}")
        return
    try:
        VerifyKey(public_key).verify(REGISTRY.read_bytes(), signature)
    except BadSignatureError:
        problems.append("registry.json.sig does not verify registry.json")


def resolve_to_disk(url: str) -> Path | None:
    if not isinstance(url, str):
        return None
    if url.startswith(PUBLIC_PREFIX):
        return CATALOG_DIR / url[len(PUBLIC_PREFIX):]
    parsed = urlparse(url)
    if parsed.scheme in ("", "file"):
        return Path(url)
    return None


def visible_alpha_fill_ratio(image: Image.Image) -> float | None:
    mask = image.getchannel("A").point(
        lambda value: 255 if value >= ICON_VISIBLE_ALPHA_THRESHOLD else 0
    )
    bbox = mask.getbbox()
    if bbox is None:
        return None
    width = bbox[2] - bbox[0]
    height = bbox[3] - bbox[1]
    return max(width, height) / max(image.size)


def validate_icon_image(slug: str, rel: str, data: bytes, problems: list[str]) -> None:
    ext = Path(rel).suffix.lower().lstrip(".")
    expected = ICON_IMAGE_EXTENSIONS.get(ext)
    if expected is None:
        problems.append(f"icon-set {slug}: icon {rel!r} must be .png or .webp")
        return
    if len(data) > ICON_IMAGE_MAX_BYTES:
        problems.append(f"icon-set {slug}: icon {rel!r} exceeds 768 KiB")
        return
    try:
        with Image.open(io.BytesIO(data)) as img:
            img.verify()
        with Image.open(io.BytesIO(data)) as img:
            fmt = img.format
            width, height = img.size
            rgba = img.convert("RGBA")
    except Exception as exc:  # noqa: BLE001 - validation should report and continue.
        problems.append(f"icon-set {slug}: icon {rel!r} is not a valid image ({exc})")
        return
    if fmt != expected:
        problems.append(f"icon-set {slug}: icon {rel!r} extension does not match {fmt}")
    if width != height:
        problems.append(f"icon-set {slug}: icon {rel!r} must be square, got {width}x{height}")
    if width < 64 or height < 64 or width > 2048 or height > 2048:
        problems.append(f"icon-set {slug}: icon {rel!r} dimensions out of range: {width}x{height}")
    visible_fill = visible_alpha_fill_ratio(rgba)
    if visible_fill is None:
        problems.append(f"icon-set {slug}: icon {rel!r} has no visible alpha footprint")
    elif visible_fill < ICON_VISIBLE_MIN_FILL:
        problems.append(
            f"icon-set {slug}: icon {rel!r} visible glyph fill {visible_fill:.3f} "
            f"below {ICON_VISIBLE_MIN_FILL:.2f}; normalize transparent padding"
        )


def scene_card_from_wallpaper(wallpaper_data: bytes) -> Image.Image:
    with Image.open(io.BytesIO(wallpaper_data)) as img:
        return img.convert("RGB").resize(CATALOG_CARD_SIZE, Image.Resampling.LANCZOS)


def validate_catalog_card_size(
    label: str,
    card_disk: Path,
    problems: list[str],
) -> bool:
    try:
        with Image.open(card_disk) as img:
            size = img.size
    except Exception as exc:  # noqa: BLE001 - validation should report and continue.
        problems.append(f"{label}: card_url image is invalid ({exc})")
        return False

    if size != CATALOG_CARD_SIZE:
        problems.append(
            f"{label}: card_url image must be {CATALOG_CARD_SIZE[0]}x{CATALOG_CARD_SIZE[1]}, "
            f"got {size[0]}x{size[1]}"
        )
        return False
    return True


def validate_scene_card_matches_wallpaper(
    slug: str,
    card_disk: Path,
    wallpaper_data: bytes,
    problems: list[str],
) -> None:
    try:
        with Image.open(card_disk) as img:
            card = img.convert("RGB")
    except Exception as exc:  # noqa: BLE001 - validation should report and continue.
        problems.append(f"scene {slug}: card_url image is invalid ({exc})")
        return

    if card.size != CATALOG_CARD_SIZE:
        return

    expected = scene_card_from_wallpaper(wallpaper_data)
    diff = ImageChops.difference(card, expected)
    rms = sum(v * v for v in ImageStat.Stat(diff).rms) ** 0.5
    if rms > SCENE_CARD_RMS_LIMIT:
        problems.append(
            f"scene {slug}: card_url image does not match wallpaper.webp derivative "
            f"(RMS {rms:.2f} > {SCENE_CARD_RMS_LIMIT:.2f})"
        )


def check_schema(data: Any, problems: list[str]) -> None:
    if not isinstance(data, dict):
        problems.append("registry must be a JSON object")
        return
    if not isinstance(data.get("version"), int) or data.get("version") != 1:
        problems.append(f"registry.version must be 1 (got {data.get('version')!r})")
    bundles = data.get("bundles")
    if not isinstance(bundles, list):
        problems.append("registry.bundles must be an array")
    starter = data.get("starter_pack") or {}
    if not isinstance(starter, dict):
        problems.append("registry.starter_pack must be an object")


def check_bundle_row(
    row: dict, idx: int, problems: list[str]
) -> tuple[str | None, str | None]:
    """Returns (type, slug) so starter-pack resolution can cross-check."""
    required = (
        "type",
        "slug",
        "name",
        "version",
        "icon_url",
        "download_url",
        "sha256",
        "size",
        "card_url",
    )
    missing = [k for k in required if k not in row]
    if missing:
        problems.append(f"bundle[{idx}]: missing keys {missing}")
        return None, None

    btype = row["type"]
    slug = row["slug"]
    version = row["version"]

    if btype not in ("scene", "icon-set", "cursor-set", "widget", "app"):
        problems.append(f"bundle[{idx}] ({slug}): unknown type {btype!r}")
    if not isinstance(slug, str) or not SLUG_RE.match(slug):
        problems.append(f"bundle[{idx}] ({slug}): invalid slug")
    if not isinstance(version, str) or not SEMVER_RE.match(version):
        problems.append(f"bundle[{idx}] ({slug}): invalid version {version!r}")

    requires = row.get("requires")
    if requires is not None:
        if not isinstance(requires, dict):
            problems.append(f"bundle[{idx}] ({slug}): requires must be an object")
        else:
            for key, value in requires.items():
                if key not in REQUIRES_KEYS:
                    problems.append(f"bundle[{idx}] ({slug}): unsupported requires key {key!r}")
                if not isinstance(value, str) or not SEMVER_RE.match(value):
                    problems.append(
                        f"bundle[{idx}] ({slug}): requires.{key} must be a semver-like string"
                    )

    sha = row["sha256"]
    if not isinstance(sha, str) or len(sha) != 64:
        problems.append(f"bundle[{idx}] ({slug}): sha256 must be 64 hex chars")

    disk = resolve_to_disk(row["download_url"])
    if disk is None or not disk.is_file():
        problems.append(
            f"bundle[{idx}] ({slug}): download_url does not resolve to a file "
            f"({row['download_url']!r} -> {disk})"
        )
        return btype, slug

    if not isinstance(row.get("size"), int) or row["size"] <= 0:
        problems.append(f"bundle[{idx}] ({slug}): size must be a positive integer")
    actual_size = disk.stat().st_size
    if row.get("size") != actual_size:
        problems.append(
            f"bundle[{idx}] ({slug}): size {row.get('size')} != on-disk {actual_size}"
        )

    if isinstance(sha, str) and len(sha) == 64:
        actual_sha = sha256_file(disk)
        if actual_sha != sha:
            problems.append(
                f"bundle[{idx}] ({slug}): sha256 mismatch — "
                f"registry has {sha}, archive is {actual_sha}"
            )

    icon_disk = resolve_to_disk(row.get("icon_url", ""))
    if row.get("icon_url") and (icon_disk is None or not icon_disk.is_file()):
        problems.append(
            f"bundle[{idx}] ({slug}): icon_url does not resolve to a file "
            f"({row['icon_url']!r})"
        )
    card_disk = resolve_to_disk(row.get("card_url", ""))
    if card_disk is None or not card_disk.is_file():
        problems.append(
            f"bundle[{idx}] ({slug}): card_url does not resolve to a file "
            f"({row.get('card_url')!r})"
        )
    elif card_disk.stat().st_size > 750 * 1024:
        problems.append(
            f"bundle[{idx}] ({slug}): card_url asset is too large "
            f"({card_disk.stat().st_size} bytes > 750 KiB)"
        )
    else:
        validate_catalog_card_size(f"bundle[{idx}] ({slug})", card_disk, problems)

    try:
        with zipfile.ZipFile(disk, "r") as zf:
            try:
                manifest_raw = zf.read("manifest.json")
            except KeyError:
                problems.append(
                    f"bundle[{idx}] ({slug}): archive missing manifest.json"
                )
                return btype, slug
            try:
                manifest = json.loads(manifest_raw)
            except json.JSONDecodeError as err:
                problems.append(
                    f"bundle[{idx}] ({slug}): manifest.json not valid JSON: {err}"
                )
                return btype, slug
            m_type = manifest.get("type")
            # Apps' internal manifests sometimes don't declare type
            # (they're pre-existing bundles). Let app rows off the hook.
            if btype == "app":
                if m_type not in (None, "app"):
                    problems.append(
                        f"bundle[{idx}] ({slug}): manifest type {m_type!r} conflicts with 'app'"
                    )
            elif m_type != btype:
                problems.append(
                    f"bundle[{idx}] ({slug}): manifest type {m_type!r} != row type {btype!r}"
                )
            if manifest.get("slug") != slug:
                problems.append(
                    f"bundle[{idx}] ({slug}): manifest slug "
                    f"{manifest.get('slug')!r} != row slug"
                )
            if manifest.get("version") != version:
                problems.append(
                    f"bundle[{idx}] ({slug}): manifest version "
                    f"{manifest.get('version')!r} != row {version!r}"
                )
            if btype == "scene":
                try:
                    wallpaper_data = zf.read("wallpaper.webp")
                except KeyError:
                    problems.append(f"bundle[{idx}] ({slug}): scene archive missing wallpaper.webp")
                else:
                    if card_disk is not None and card_disk.is_file():
                        validate_scene_card_matches_wallpaper(slug, card_disk, wallpaper_data, problems)
            if btype == "icon-set":
                icons = manifest.get("icons")
                if not isinstance(icons, dict):
                    problems.append(f"bundle[{idx}] ({slug}): icon-set manifest missing icons")
                else:
                    missing_icons = sorted(FIRST_PARTY_ICON_KEYS - set(icons.keys()))
                    if missing_icons:
                        problems.append(
                            f"bundle[{idx}] ({slug}): first-party icon set missing icons {missing_icons}"
                        )
                    for key, rel in icons.items():
                        if not isinstance(rel, str):
                            problems.append(
                                f"bundle[{idx}] ({slug}): icon {key!r} path must be a string"
                            )
                            continue
                        try:
                            data = zf.read(rel)
                        except KeyError:
                            problems.append(
                                f"bundle[{idx}] ({slug}): icon {rel!r} missing from archive"
                            )
                            continue
                        validate_icon_image(slug, rel, data, problems)
            if btype == "app":
                if not row.get("icon_url"):
                    problems.append(f"bundle[{idx}] ({slug}): app row missing icon_url")
                icon = manifest.get("icon")
                if not isinstance(icon, str) or not icon:
                    problems.append(f"bundle[{idx}] ({slug}): app manifest missing icon")
                elif not icon.startswith(("http://", "https://")) and icon not in zf.namelist():
                    problems.append(
                        f"bundle[{idx}] ({slug}): app manifest icon {icon!r} missing from archive"
                    )
                entry = manifest.get("entry") or "index.html"
                if isinstance(entry, str):
                    try:
                        html = zf.read(entry).decode("utf-8", errors="replace")
                    except KeyError:
                        html = ""
                    for ref in sorted(set(re.findall(r"""(?:src|href)=["']([^"']+)["']""", html))):
                        if ref.startswith(("http://", "https://", "data:", "/", "#")):
                            continue
                        clean = ref.split("?", 1)[0].split("#", 1)[0].lstrip("./")
                        if clean and clean not in zf.namelist():
                            problems.append(
                                f"bundle[{idx}] ({slug}): index.html references missing asset {ref!r}"
                            )
    except zipfile.BadZipFile:
        problems.append(f"bundle[{idx}] ({slug}): .wp is not a valid ZIP")

    return btype, slug


def check_starter_pack(
    data: dict, index: dict[str, set[str]], problems: list[str]
) -> None:
    starter = data.get("starter_pack") or {}
    mapping = {
        "scenes": "scene",
        "iconSets": "icon-set",
        "cursorSets": "cursor-set",
        "widgets": "widget",
        "apps": "app",
    }
    for group, type_key in mapping.items():
        entries = starter.get(group) or []
        if not isinstance(entries, list):
            problems.append(f"starter_pack.{group} must be an array")
            continue
        known = index.get(type_key, set())
        for slug in entries:
            if slug not in known:
                problems.append(
                    f"starter_pack.{group}: no {type_key} bundle found with slug {slug!r}"
                )


def catalog_artifact_paths() -> list[Path]:
    paths = (
        list((CATALOG_DIR / "bundles").glob("*.wp"))
        + list((CATALOG_DIR / "icons").glob("*"))
        + list((CATALOG_DIR / "cards").glob("*"))
        + [REGISTRY, SCHEMA, FALLBACK_REGISTRY]
    )
    if REGISTRY_SIG.is_file():
        paths.append(REGISTRY_SIG)
    return sorted(p for p in paths if p.is_file())


def check_fallback_registry(problems: list[str]) -> None:
    if not FALLBACK_REGISTRY.is_file():
        problems.append(
            f"{FALLBACK_REGISTRY.relative_to(REPO_ROOT)} is missing"
        )
        return
    if sha256_file(FALLBACK_REGISTRY) != sha256_file(REGISTRY):
        problems.append(
            f"{FALLBACK_REGISTRY.relative_to(REPO_ROOT)} differs from "
            f"{REGISTRY.relative_to(REPO_ROOT)}"
        )


def check_deterministic_rebuild(problems: list[str]) -> None:
    """Optional: rebuild the catalog and confirm the on-disk tree is
    byte-identical. Gated behind an env flag so normal local runs stay
    fast."""
    if not (REPO_ROOT / "_tools" / "build-catalog.py").is_file():
        return
    if os.environ.get("ODD_VALIDATE_REBUILD") != "1":
        return
    # Snapshot shas of every published catalog artifact plus the
    # frozen in-plugin fallback mirror. Storefront-only changes often
    # touch icons without changing bundles, so icons must be covered.
    paths = catalog_artifact_paths()
    before = {p: sha256_file(p) for p in paths}

    try:
        subprocess.run(
            [sys.executable, str(REPO_ROOT / "_tools" / "build-catalog.py")],
            check=True,
            capture_output=True,
        )
    except subprocess.CalledProcessError as err:
        problems.append(f"rebuild failed: {err.stderr.decode(errors='replace')}")
        return

    paths = catalog_artifact_paths()
    after = {p: sha256_file(p) for p in paths}
    if set(before) != set(after):
        diffs = sorted(str(p.relative_to(REPO_ROOT)) for p in set(before) ^ set(after))
        problems.append(f"rebuild changed file set: {diffs}")
        return
    for p in paths:
        if before[p] != after[p]:
            problems.append(
                f"rebuild changed {p.relative_to(REPO_ROOT)} — builder is non-deterministic"
            )


def main() -> int:
    problems: list[str] = []

    if not REGISTRY.is_file():
        print(
            f"error: {REGISTRY.relative_to(REPO_ROOT)} not found. "
            f"Run `python3 _tools/build-catalog.py` first.",
            file=sys.stderr,
        )
        return 1

    try:
        data = json.loads(REGISTRY.read_text(encoding="utf-8"))
    except json.JSONDecodeError as err:
        print(f"error: registry.json is not valid JSON: {err}", file=sys.stderr)
        return 1

    check_registry_signature(problems)
    check_schema(data, problems)

    bundles = data.get("bundles") or []
    index: dict[str, set[str]] = {}
    for idx, row in enumerate(bundles):
        if not isinstance(row, dict):
            problems.append(f"bundle[{idx}] is not an object")
            continue
        btype, slug = check_bundle_row(row, idx, problems)
        if btype and slug:
            index.setdefault(btype, set()).add(slug)

    check_starter_pack(data, index, problems)
    check_fallback_registry(problems)
    check_deterministic_rebuild(problems)

    if problems:
        print("catalog validation failed:\n", file=sys.stderr)
        for p in problems:
            print(f"  - {p}", file=sys.stderr)
        return 1

    counts = {t: len(slugs) for t, slugs in index.items()}
    total = sum(counts.values())
    print(
        f"catalog ok: {total} bundles "
        f"({', '.join(f'{t}={n}' for t, n in sorted(counts.items()))})"
    )
    return 0


if __name__ == "__main__":
    sys.exit(main())
