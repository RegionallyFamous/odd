#!/usr/bin/env python3
"""Validate cursor-effect catalog sources."""
from __future__ import annotations

import json
import re
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

ROOT = Path(__file__).resolve().parents[2]
SRC = ROOT / "_tools" / "catalog-sources" / "cursor-sets"
CTRL = re.compile(rb"[\x00-\x08\x0b\x0c\x0e-\x1f]")
HEX = re.compile(r"^#[0-9A-Fa-f]{3,8}$")
EFFECT_KEYS = {"accent", "spark", "warm", "ink", "recipe"}
RECIPES = {"signal-bloom", "gel-pop", "paper-sparks", "solar-orbit", "moonlight-focus"}


def fail(problems: list[str], msg: str) -> None:
    problems.append(msg)


def main() -> int:
    problems: list[str] = []
    if not SRC.is_dir():
        return 0
    for folder in sorted(p for p in SRC.iterdir() if p.is_dir()):
        manifest_path = folder / "manifest.json"
        if not manifest_path.is_file():
            fail(problems, f"{folder.name}: missing manifest.json")
            continue
        try:
            manifest = json.loads(manifest_path.read_text())
        except json.JSONDecodeError as exc:
            fail(problems, f"{folder.name}: invalid manifest.json: {exc}")
            continue
        cursors = manifest.get("cursors") or {}
        if cursors:
            fail(problems, f"{folder.name}: cursor image files are no longer supported; use effects instead")
            continue
        effects = manifest.get("effects") or {}
        if not isinstance(effects, dict):
            fail(problems, f"{folder.name}: effects must be an object")
            continue
        for key, value in effects.items():
            if key not in EFFECT_KEYS:
                fail(problems, f"{folder.name}: unsupported effect token {key!r}")
                continue
            if key == "recipe":
                if not isinstance(value, str) or value not in RECIPES:
                    fail(problems, f"{folder.name}: unsupported effect recipe {value!r}")
                continue
            if not isinstance(value, str) or not HEX.fullmatch(value):
                fail(problems, f"{folder.name}: effect token {key!r} must be a hex color")
        preview = manifest.get("preview")
        if isinstance(preview, str) and preview:
            if Path(preview).name != preview or "\\" in preview or ".." in preview:
                fail(problems, f"{folder.name}: preview path {preview!r} must be flat")
                continue
            path = folder / preview
            if not path.is_file():
                fail(problems, f"{folder.name}: missing {preview}")
                continue
            if path.suffix.lower() != ".svg":
                continue
            data = path.read_bytes()
            if len(data) > 8192:
                fail(problems, f"{folder.name}: {preview} exceeds 8 KB")
            if CTRL.search(data):
                fail(problems, f"{folder.name}: {preview} contains control bytes")
            try:
                root = ET.fromstring(data)
            except ET.ParseError as exc:
                fail(problems, f"{folder.name}: {preview} invalid XML: {exc}")
                continue
            if root.tag != "{http://www.w3.org/2000/svg}svg":
                fail(problems, f"{folder.name}: {preview} root is not <svg>")
    if problems:
        print("Cursor-set validation failed:", file=sys.stderr)
        for problem in problems:
            print(f" - {problem}", file=sys.stderr)
        return 1
    print("Cursor effect packs OK")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
