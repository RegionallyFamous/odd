#!/usr/bin/env python3
"""Assert Version header + ODDOUT_VERSION constant agree, and blueprint refs when tagged.

With --expect <x.y.z>, assert the plugin header and constant match that value.
When Playground blueprints install ODD via a semver git **tag**, that tag must
also match `odd.php`. Branch installs (`main`) skip blueprint↔semver checks.

Usage:
    odd/bin/check-version
    odd/bin/check-version --expect 0.1.0
"""
from __future__ import annotations

import argparse
import json
import re
import sys
from pathlib import Path


HERE = Path(__file__).resolve().parent
PLUGIN_DIR = HERE.parent
PLUGIN = PLUGIN_DIR / "odd.php"
REPO_ROOT = PLUGIN_DIR.parent
BLUEPRINT = REPO_ROOT / "blueprint.json"
SITE_BLUEPRINT = REPO_ROOT / "site" / "playground" / "blueprint.json"


SENTINEL_GIT_DIRECTORY = "__git_directory__"


def blueprint_install_ref(path: Path) -> str | None:
    """Inspect how blueprint.json installs the ODD plugin.

    Returns one of:
      - a bare x.y.z value if the blueprint pins ODD to a vX.Y.Z git tag
      - SENTINEL_GIT_DIRECTORY if the blueprint pulls ODD via another
        `git:directory` ref against `RegionallyFamous/odd`.
      - None if no recognizable ODD install step is present.
    """
    if not path.exists():
        return None
    try:
        data = json.loads(path.read_text())
    except json.JSONDecodeError:
        return None
    for step in data.get("steps", []):
        if not isinstance(step, dict) or step.get("step") != "installPlugin":
            continue
        plugin_data = step.get("pluginData") or {}
        resource = plugin_data.get("resource")
        if resource == "git:directory":
            repo = plugin_data.get("url", "")
            if "RegionallyFamous/odd" in repo:
                ref_type = plugin_data.get("refType", "")
                ref = str(plugin_data.get("ref", ""))
                if ref_type == "tag" and re.match(r"^v[0-9]+\.[0-9]+\.[0-9]+$", ref):
                    return ref[1:]
                return SENTINEL_GIT_DIRECTORY
            continue
    return None


def main() -> int:
    parser = argparse.ArgumentParser(description="Check that ODD versions are in sync.")
    parser.add_argument("--expect", help="also assert all match this value", default=None)
    args = parser.parse_args()

    if not PLUGIN.exists():
        print(f"error: missing {PLUGIN}", file=sys.stderr)
        return 1

    text = PLUGIN.read_text()

    header = re.search(r"^\s*\*\s*Version:\s*([0-9]+\.[0-9]+\.[0-9]+)\s*$", text, re.MULTILINE)
    constant = re.search(
        r"define\(\s*['\"]ODDOUT_VERSION['\"]\s*,\s*['\"]([0-9]+\.[0-9]+\.[0-9]+)['\"]\s*\)",
        text,
    )

    found: dict[str, str | None] = {
        "Version: header": header.group(1) if header else None,
        "ODDOUT_VERSION": constant.group(1) if constant else None,
    }

    blueprint_refs: dict[str, str] = {}
    for label, path in (
        ("blueprint.json ref", BLUEPRINT),
        ("site/playground/blueprint.json ref", SITE_BLUEPRINT),
    ):
        blueprint_ref = blueprint_install_ref(path)
        if blueprint_ref is None:
            print(
                f"error: could not find the ODD installPlugin step in {path.relative_to(REPO_ROOT)}",
                file=sys.stderr,
            )
            return 1
        blueprint_refs[label] = blueprint_ref
        if blueprint_ref != SENTINEL_GIT_DIRECTORY:
            found[label] = blueprint_ref

    missing = [k for k, v in found.items() if v is None]
    if missing:
        for k in missing:
            print(f"error: could not find {k}", file=sys.stderr)
        return 1

    unique = set(found.values())
    if len(unique) != 1:
        print("error: version strings disagree:", file=sys.stderr)
        for k, v in found.items():
            print(f"  {k}: {v}", file=sys.stderr)
        return 1

    version = next(iter(unique))

    if args.expect is not None and version != args.expect:
        print(
            f"error: committed version is {version} but expected {args.expect}",
            file=sys.stderr,
        )
        return 1

    if all(ref == SENTINEL_GIT_DIRECTORY for ref in blueprint_refs.values()):
        print(
            f"OK: odd.php version {version} (blueprint installs ODD via git:directory)"
        )
    else:
        print(f"OK: odd.php + blueprint.json install ref version {version}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
