#!/usr/bin/env python3
"""Validate the contents of dist/odd.zip before release."""
from __future__ import annotations

import argparse
import sys
import zipfile
from pathlib import PurePosixPath


REQUIRED = {
    "odd/odd.php",
    "odd/readme.txt",
    "odd/uninstall.php",
    "odd/languages/odd-outlandish-desktop-decorator.pot",
    "odd/includes/dependencies.php",
    "odd/includes/enqueue.php",
    "odd/includes/content/bootstrap.php",
    "odd/src/panel/index.js",
    "odd/src/shared/api.js",
}

FORBIDDEN_PARTS = {
    ".cursor",
    ".git",
    ".github",
    "__pycache__",
    "_tools",
    "ci",
    "dist",
    "node_modules",
    "tests",
    "vendor",
}

FORBIDDEN_NAMES = {
    ".DS_Store",
    ".env",
    ".env.local",
    ".gitignore",
    ".gitkeep",
    "composer.json",
    "composer.lock",
    "package.json",
    "package-lock.json",
    "phpcs.xml.dist",
}

FORBIDDEN_SUFFIXES = {
    ".bak",
    ".log",
    ".map",
    ".plan.md",
    ".py",
    ".pyc",
    ".tmp",
}


def main() -> int:
    parser = argparse.ArgumentParser(description="Check ODD release zip contents.")
    parser.add_argument("zipfile", nargs="?", default="dist/odd.zip")
    parser.add_argument("--list", action="store_true", help="print archive contents")
    args = parser.parse_args()

    try:
        with zipfile.ZipFile(args.zipfile) as zf:
            names = sorted(name for name in zf.namelist() if not name.endswith("/"))
    except FileNotFoundError:
        print(f"error: missing {args.zipfile}", file=sys.stderr)
        return 1
    except zipfile.BadZipFile:
        print(f"error: {args.zipfile} is not a valid zip", file=sys.stderr)
        return 1

    if args.list:
        for name in names:
            print(name)

    missing = sorted(REQUIRED.difference(names))
    if missing:
        print("error: release zip is missing required files:", file=sys.stderr)
        for name in missing:
            print(f"  {name}", file=sys.stderr)
        return 1

    forbidden: list[str] = []
    for name in names:
        path = PurePosixPath(name)
        if path.parts[0] != "odd":
            forbidden.append(f"{name} (not under odd/)")
            continue
        if any(part in FORBIDDEN_PARTS for part in path.parts):
            forbidden.append(name)
            continue
        if path.name.startswith("."):
            forbidden.append(name)
            continue
        if path.name in FORBIDDEN_NAMES:
            forbidden.append(name)
            continue
        if any(path.name.endswith(suffix) for suffix in FORBIDDEN_SUFFIXES):
            forbidden.append(name)

    if forbidden:
        print("error: release zip contains forbidden files:", file=sys.stderr)
        for name in forbidden:
            print(f"  {name}", file=sys.stderr)
        return 1

    print(f"OK: {args.zipfile} contains {len(names)} release files and no forbidden paths")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
