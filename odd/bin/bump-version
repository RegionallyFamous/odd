#!/usr/bin/env python3
"""Bump every place ODD's version is pinned, in one command.

Updates all declared versions in sync:
  1. `Version:` header in odd/odd.php
  2. `ODDOUT_VERSION` constant in odd/odd.php
  3. ODD Playground install: **`git:directory`** `refType: commit` with the peeled
     SHA of **`v` + `ODDOUT_VERSION`** when that tag exists locally; otherwise **`tag`**
     + `v` + version until you tag and re-run bump (Playground avoids flaky tag packs).

Usage:
    odd/bin/bump-version 0.14.0            # edits in place
    odd/bin/bump-version 0.14.0 --dry-run  # prints what would change

Run odd/bin/check-version after bumping to confirm everything agrees.
"""
from __future__ import annotations

import argparse
import json
import re
import subprocess
import sys
from pathlib import Path


HERE = Path(__file__).resolve().parent
PLUGIN_DIR = HERE.parent
PLUGIN = PLUGIN_DIR / "odd.php"
REPO_ROOT = PLUGIN_DIR.parent
BLUEPRINT = REPO_ROOT / "blueprint.json"
SITE_BLUEPRINT = REPO_ROOT / "site" / "playground" / "blueprint.json"

SEMVER_RE = re.compile(r"^[0-9]+\.[0-9]+\.[0-9]+$")


def bump_plugin(text: str, new_version: str) -> tuple[str, list[str]]:
    """Replace the Version: header + ODDOUT_VERSION constant in odd.php.

    Returns (new_text, summary_lines).
    """
    lines: list[str] = []
    new_text, header_subs = re.subn(
        r"(^\s*\*\s*Version:\s*)[0-9]+\.[0-9]+\.[0-9]+(\s*)$",
        lambda m: f"{m.group(1)}{new_version}{m.group(2)}",
        text,
        count=1,
        flags=re.MULTILINE,
    )
    if header_subs != 1:
        raise SystemExit("error: could not find a `Version:` header in odd.php")
    lines.append("  odd.php: Version: header -> " + new_version)

    new_text, const_subs = re.subn(
        r"(define\(\s*['\"]ODDOUT_VERSION['\"]\s*,\s*['\"])[0-9]+\.[0-9]+\.[0-9]+(['\"]\s*\))",
        lambda m: f"{m.group(1)}{new_version}{m.group(2)}",
        new_text,
        count=1,
    )
    if const_subs != 1:
        raise SystemExit("error: could not find the ODDOUT_VERSION constant in odd.php")
    lines.append("  odd.php: ODDOUT_VERSION constant -> " + new_version)

    return new_text, lines


def peel_release_tag(repo_root: Path, version: str) -> str | None:
    """Return `git rev-parse v{version}^{commit}` when the tag exists locally."""

    if not (repo_root / ".git").exists():
        return None
    tag = "v" + version
    try:
        out = subprocess.check_output(
            ["git", "-C", str(repo_root), "rev-parse", tag + "^{commit}"],
            stderr=subprocess.DEVNULL,
            text=True,
            timeout=30,
        )
    except (
        subprocess.CalledProcessError,
        FileNotFoundError,
        subprocess.TimeoutExpired,
    ):
        return None
    digest = out.strip()
    return digest if re.fullmatch(r"[0-9a-f]{40}", digest) else None


def bump_blueprint(text: str, new_version: str, label: str) -> tuple[str, list[str]]:
    """Rewrite ODD's `git:directory` pin to peeled commit or semver tag.

    Returns (new_text, summary_lines).
    """
    lines: list[str] = []
    try:
        data = json.loads(text)
    except json.JSONDecodeError as e:
        raise SystemExit(f"error: {label} is not valid JSON: {e}") from e

    steps = data.get("steps")
    if not isinstance(steps, list):
        raise SystemExit(f"error: {label} has no steps array")

    matched = False
    for step in steps:
        if not isinstance(step, dict) or step.get("step") != "installPlugin":
            continue
        plugin = step.get("pluginData")
        if not isinstance(plugin, dict):
            continue
        if plugin.get("resource") != "git:directory":
            continue
        if "RegionallyFamous/odd" not in str(plugin.get("url", "")):
            continue

        rt = plugin.get("refType", "")
        cr = plugin.get("ref", "")
        if rt == "branch" and cr == "main":
            lines.append(
                f"  {label}: ODD branch main — skipped (release bump not applicable)"
            )
            return text, lines

        tag = "v" + new_version
        peel = peel_release_tag(REPO_ROOT, new_version)
        if peel:
            plugin["ref"] = peel
            plugin["refType"] = "commit"
            lines.append(
                f"  {label}: ODD git -> commit {peel[:7]}… (peel of {tag})"
            )
        else:
            plugin["ref"] = tag
            plugin["refType"] = "tag"
            lines.append(
                f"  {label}: ODD git -> {tag} (no local tag peel yet — after `git tag`, re-run bump for commit pin)"
            )
        matched = True
        break

    if not matched:
        raise SystemExit(f"error: could not find ODD release installPlugin step in {label}")

    new_text = json.dumps(data, indent=2) + "\n"
    return new_text, lines


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__.splitlines()[0])
    parser.add_argument("version", help="new semver, e.g. 0.14.0")
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="print what would change, don't write",
    )
    args = parser.parse_args()

    if not SEMVER_RE.match(args.version):
        print(f"error: '{args.version}' is not x.y.z semver", file=sys.stderr)
        return 2

    if not PLUGIN.exists():
        print(f"error: missing {PLUGIN}", file=sys.stderr)
        return 1
    if not BLUEPRINT.exists():
        print(f"error: missing {BLUEPRINT}", file=sys.stderr)
        return 1
    if not SITE_BLUEPRINT.exists():
        print(f"error: missing {SITE_BLUEPRINT}", file=sys.stderr)
        return 1

    summary: list[str] = []

    plugin_text = PLUGIN.read_text()
    new_plugin_text, plugin_lines = bump_plugin(plugin_text, args.version)
    summary.extend(plugin_lines)

    blueprint_text = BLUEPRINT.read_text()
    new_blueprint_text, blueprint_lines = bump_blueprint(
        blueprint_text,
        args.version,
        "blueprint.json",
    )
    summary.extend(blueprint_lines)

    site_blueprint_text = SITE_BLUEPRINT.read_text()
    new_site_blueprint_text, site_blueprint_lines = bump_blueprint(
        site_blueprint_text,
        args.version,
        "site/playground/blueprint.json",
    )
    summary.extend(site_blueprint_lines)

    print(f"bumping ODD to {args.version}:")
    for line in summary:
        print(line)

    if args.dry_run:
        print("(dry run — nothing written)")
        return 0

    if new_plugin_text != plugin_text:
        PLUGIN.write_text(new_plugin_text)
    if new_blueprint_text != blueprint_text:
        BLUEPRINT.write_text(new_blueprint_text)
    if new_site_blueprint_text != site_blueprint_text:
        SITE_BLUEPRINT.write_text(new_site_blueprint_text)

    print("done. run `odd/bin/check-version` to confirm.")
    return 0


if __name__ == "__main__":
    sys.exit(main())
