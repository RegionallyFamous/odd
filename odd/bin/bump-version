#!/usr/bin/env python3
"""Bump every place ODD's version is pinned, in one command.

Updates all declared versions in sync:
  1. `Version:` header in odd/odd.php
  2. `ODD_VERSION` constant in odd/odd.php
  3. `v<x.y.z>` release tag ref in each Playground blueprint.json *when* the
     hosted demo installs ODD from a semver git tag.

Public Playground blueprints install ODD via `git:directory` **tag `v`
+ `ODD_VERSION`** and Desktop Mode via **`resource: "url"`** pointing at
`https://downloads.wordpress.org/plugin/desktop-mode.{version}.zip`
where `{version}` is `ODD_DESKTOP_MODE_MIN_VERSION` (the Playground
schema does not allow pinning versions on `wordpress.org/plugins`).
`odd/bin/validate-blueprint` enforces both against `odd/odd.php`.
`odd/bin/bump-version` rewrites blueprint ODD `ref` pins when tagging a new semver release.

Usage:
    odd/bin/bump-version 0.14.0            # edits in place
    odd/bin/bump-version 0.14.0 --dry-run  # prints what would change

Run odd/bin/check-version after bumping to confirm everything agrees.
"""
from __future__ import annotations

import argparse
import json
import re
import sys
from pathlib import Path


HERE = Path(__file__).resolve().parent
PLUGIN_DIR = HERE.parent
PLUGIN = PLUGIN_DIR / "odd.php"
REPO_ROOT = PLUGIN_DIR.parent
BLUEPRINT = REPO_ROOT / "blueprint.json"
SITE_BLUEPRINT = REPO_ROOT / "site" / "playground" / "blueprint.json"

SEMVER_RE = re.compile(r"^[0-9]+\.[0-9]+\.[0-9]+$")


def bump_plugin(text: str, new_version: str) -> tuple[str, list[str]]:
    """Replace the Version: header + ODD_VERSION constant in odd.php.

    Returns (new_text, summary_lines).
    """
    lines: list[str] = []
    new_text, header_subs = re.subn(
        r"(^\s*\*\s*Version:\s*)[0-9]+\.[0-9]+\.[0-9]+(\s*)$",
        lambda m: f"{m.group(1)}{new_version}{m.group(2)}",
        text,
        count=1,
        flags=re.MULTILINE,
    )
    if header_subs != 1:
        raise SystemExit("error: could not find a `Version:` header in odd.php")
    lines.append("  odd.php: Version: header -> " + new_version)

    new_text, const_subs = re.subn(
        r"(define\(\s*['\"]ODD_VERSION['\"]\s*,\s*['\"])[0-9]+\.[0-9]+\.[0-9]+(['\"]\s*\))",
        lambda m: f"{m.group(1)}{new_version}{m.group(2)}",
        new_text,
        count=1,
    )
    if const_subs != 1:
        raise SystemExit("error: could not find the ODD_VERSION constant in odd.php")
    lines.append("  odd.php: ODD_VERSION constant -> " + new_version)

    return new_text, lines


def odd_blueprint_install_ref(text: str, label: str) -> tuple[str | None, str | None]:
    """Return (refType, ref) for ODD's git:directory install step, or (None, None).

    Exits the process if JSON is invalid or the ODD step is missing.
    """
    try:
        data = json.loads(text)
    except json.JSONDecodeError as e:
        raise SystemExit(f"error: {label} is not valid JSON: {e}") from e
    steps = data.get("steps")
    if not isinstance(steps, list):
        raise SystemExit(f"error: {label} has no steps array")
    for step in steps:
        if not isinstance(step, dict) or step.get("step") != "installPlugin":
            continue
        plugin = step.get("pluginData")
        if not isinstance(plugin, dict):
            continue
        if plugin.get("resource") != "git:directory":
            continue
        if "RegionallyFamous/odd" not in str(plugin.get("url", "")):
            continue
        ref_type = plugin.get("refType")
        ref = plugin.get("ref")
        if not isinstance(ref_type, str) or not isinstance(ref, str):
            raise SystemExit(f"error: ODD git step in {label} has invalid ref/refType")
        return ref_type, ref
    raise SystemExit(f"error: could not find ODD installPlugin step in {label}")


def bump_blueprint(text: str, new_version: str, label: str) -> tuple[str, list[str]]:
    """Replace `v<x.y.z>` in ODD's git:directory ref, or skip branch-main installs.

    Returns (new_text, summary_lines).
    """
    lines: list[str] = []
    ref_type, cur_ref = odd_blueprint_install_ref(text, label)
    if ref_type == "branch" and cur_ref == "main":
        lines.append(f"  {label}: ODD branch main — skipped (release tag bump not applicable)")
        return text, lines

    ref_re = re.compile(
        r'("url"\s*:\s*"https://github\.com/RegionallyFamous/odd"\s*,\s*\n'
        r'\s*"ref"\s*:\s*")v[0-9]+\.[0-9]+\.[0-9]+(")'
    )
    matches = list(ref_re.finditer(text))
    if not matches:
        raise SystemExit(
            f"error: could not find a semver git tag ref for ODD in {label} "
            f"(refType={ref_type!r}, ref={cur_ref!r})"
        )
    if len(matches) > 1:
        raise SystemExit(
            f"error: {label} contains {len(matches)} ODD release refs "
            "(expected exactly 1) — cowardly refusing to guess which to bump"
        )

    new_text = ref_re.sub(
        lambda m: f"{m.group(1)}v{new_version}{m.group(2)}",
        text,
        count=1,
    )

    try:
        json.loads(new_text)
    except json.JSONDecodeError as e:
        raise SystemExit(f"error: {label} stopped being valid JSON after edit: {e}") from e

    lines.append(f"  {label}: ODD git tag -> v{new_version}")
    return new_text, lines


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__.splitlines()[0])
    parser.add_argument("version", help="new semver, e.g. 0.14.0")
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="print what would change, don't write",
    )
    args = parser.parse_args()

    if not SEMVER_RE.match(args.version):
        print(f"error: '{args.version}' is not x.y.z semver", file=sys.stderr)
        return 2

    if not PLUGIN.exists():
        print(f"error: missing {PLUGIN}", file=sys.stderr)
        return 1
    if not BLUEPRINT.exists():
        print(f"error: missing {BLUEPRINT}", file=sys.stderr)
        return 1
    if not SITE_BLUEPRINT.exists():
        print(f"error: missing {SITE_BLUEPRINT}", file=sys.stderr)
        return 1

    summary: list[str] = []

    plugin_text = PLUGIN.read_text()
    new_plugin_text, plugin_lines = bump_plugin(plugin_text, args.version)
    summary.extend(plugin_lines)

    blueprint_text = BLUEPRINT.read_text()
    new_blueprint_text, blueprint_lines = bump_blueprint(
        blueprint_text,
        args.version,
        "blueprint.json",
    )
    summary.extend(blueprint_lines)

    site_blueprint_text = SITE_BLUEPRINT.read_text()
    new_site_blueprint_text, site_blueprint_lines = bump_blueprint(
        site_blueprint_text,
        args.version,
        "site/playground/blueprint.json",
    )
    summary.extend(site_blueprint_lines)

    print(f"bumping ODD to {args.version}:")
    for line in summary:
        print(line)

    if args.dry_run:
        print("(dry run — nothing written)")
        return 0

    if new_plugin_text != plugin_text:
        PLUGIN.write_text(new_plugin_text)
    if new_blueprint_text != blueprint_text:
        BLUEPRINT.write_text(new_blueprint_text)
    if new_site_blueprint_text != site_blueprint_text:
        SITE_BLUEPRINT.write_text(new_site_blueprint_text)

    print("done. run `odd/bin/check-version` to confirm.")
    return 0


if __name__ == "__main__":
    sys.exit(main())
