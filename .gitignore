# Build output
dist/
node_modules/
vendor/
__pycache__/
*.pyc

# OS / editor / lint caches
.DS_Store
.phpcs-cache
*.swp

# Local e2e WordPress tree (bin/e2e-local.sh)
.e2e/

# Playwright output (never commit ephemeral reports)
/playwright-report/
/test-results/

# Hosted Playground zips should come from WordPress.org or release artifacts,
# not checked-in snapshots.
site/downloads/*.zip
site/vendor/*.zip

# ODD ships empty — bundle content lives in the remote catalog at
# _tools/catalog-sources/. These legacy plugin asset folders must not
# ship inside the plugin zip. Keep them out of git so a casual
# `git add -A` never re-adds a multi-megabyte payload.
odd/assets/wallpapers/
odd/assets/previews/
