# ODD ships empty — bundle content lives in the remote catalog at
# _tools/catalog-sources/. These legacy plugin asset folders must not
# ship inside the plugin zip. Keep them out of git so a casual
# `git add -A` never re-adds a multi-megabyte payload.
odd/assets/wallpapers/
odd/assets/previews/
