{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "landingPage": "/wp-admin/index.php?desktop_mode_portal=1",
  "preferredVersions": {
    "php": "8.0",
    "wp": "6.9"
  },
  "features": {
    "networking": true
  },
  "login": true,
  "steps": [
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "url",
        "url": "https://downloads.wordpress.org/plugin/desktop-mode.0.7.2.zip"
      },
      "options": { "activate": true, "targetFolderName": "desktop-mode" }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "git:directory",
        "url": "https://github.com/RegionallyFamous/odd",
        "ref": "v1.0.2",
        "refType": "tag",
        "path": "odd"
      },
      "options": { "activate": true, "targetFolderName": "odd" }
    },
    {
      "step": "updateUserMeta",
      "userId": 1,
      "meta": { "desktop_mode_mode": "1" }
    }
  ]
}
